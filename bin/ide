#!/bin/bash
# tmux ide mode with layout selection via fzf

layout=$(printf '%s\n' \
  "default: 2pane split" \
  "dev: yazi + claude + lazygit" \
| fzf --prompt="layout> " --height=10 --reverse)

[ -z "$layout" ] && exit 0

case "$layout" in
  default*)
    tmux split-window -h -p 50
    tmux split-window -p 50
    tmux select-pane -R
    clear
    ;;
  dev*)
    dir=""
    if command -v git-wt &>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
      # First: select operation mode
      mode=$(printf '%s\n' \
        "new: 新しいブランチからworktreeを作成" \
        "existing-wt: 既存のworktreeを選択" \
        "existing-branch: 既存のブランチからworktreeを作成" \
      | fzf --prompt="mode> " --height=10 --reverse)

      [ -z "$mode" ] && exit 0

      case "$mode" in
        new*)
          # Read branch name from user
          printf "branch name: "
          read -r branch_name
          [ -z "$branch_name" ] && exit 0

          # Optionally select start-point from remote branches (default branch first)
          default_branch=$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null)
          all_branches=$(git branch -r --format='%(refname:short)')
          if [ -n "$default_branch" ]; then
            start_point=$(printf '%s\n%s' "origin/$default_branch" "$(echo "$all_branches" | grep -v "origin/$default_branch")" | sed '/^$/d' | fzf --prompt="start-point> " --height=20 --reverse --header="Select start-point (ESC to use HEAD)")
          else
            start_point=$(echo "$all_branches" | fzf --prompt="start-point> " --height=20 --reverse --header="Select start-point (ESC to use HEAD)")
          fi

          # Fetch latest before creating worktree
          if [ -n "$start_point" ]; then
            remote_branch="${start_point#origin/}"
            git fetch origin "$remote_branch"
            git wt "$branch_name" "$start_point"
          else
            git wt "$branch_name"
          fi
          dir=$(git wt "$branch_name" 2>/dev/null | tail -1)
          ;;
        existing-wt*)
          wt_list=$(git wt 2>/dev/null | tail -n +2)
          [ -z "$wt_list" ] && echo "No existing worktrees." && exit 0
          selected=$(echo "$wt_list" | fzf --prompt="worktree> " --height=20 --reverse --header="Select worktree")
          [ -z "$selected" ] && exit 0
          wt_path=$(echo "$selected" | awk '{print $(NF-1)}')
          dir=$(git wt "$wt_path" 2>/dev/null | tail -1)
          ;;
        existing-branch*)
          git fetch --all --prune 2>/dev/null
          # Show local + remote branches
          all_branches=$(git branch -a --format='%(refname:short)' | sort -u)
          [ -z "$all_branches" ] && echo "No branches found." && exit 0
          selected_branch=$(echo "$all_branches" | fzf --prompt="branch> " --height=20 --reverse --header="Select branch to create worktree")
          [ -z "$selected_branch" ] && exit 0

          # For remote branches, strip origin/ prefix for worktree name
          wt_name="${selected_branch#origin/}"
          git wt "$wt_name" "$selected_branch" 2>/dev/null
          dir=$(git wt "$wt_name" 2>/dev/null | tail -1)
          ;;
      esac
    fi
    dir="${dir:-$(pwd)}"
    [ ! -d "$dir" ] && dir="$(pwd)"

    tmux split-window -h -p 50 -c "$dir"
    tmux split-window -v -p 40 -c "$dir"
    tmux send-keys 'clear' Enter
    tmux select-pane -U
    tmux send-keys 'claude' Enter
    tmux select-pane -L
    tmux send-keys "cd '$dir' && vi ." Enter
    tmux select-pane -R
    tmux select-pane -U
    ;;
esac
